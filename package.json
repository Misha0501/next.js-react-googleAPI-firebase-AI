{
  "name": "real-estate-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "prisma-db-push-dev": "dotenv -e .env.development -- npx prisma db push",
    "prisma-db-push-remote": "dotenv -e .env.production.local --override -- npx prisma db push",
    "prisma-db-generate-dev": "dotenv -e .env.development -- npx prisma generate",
    "prisma-db-seed-dev": "dotenv -e .env.development -- node prisma/seed.js",
    "prisma-db-seed-dev:remote-images": "dotenv -e .env.development -v SEED_IMAGE_SOURCE=remote -- node prisma/seed.js",
    "prisma-db-seed-remote": "dotenv -e .env.production.local --override -v SEED_IMAGE_SOURCE=remote -- node prisma/seed.js",
    "prisma-db-setup-dev": "npm run prisma-db-push-dev && npm run prisma-db-seed-dev",
    "prisma-db-setup-remote": "npm run prisma-db-push-remote && npm run prisma-db-seed-remote"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^1.0.1",
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.0.18",
    "@prisma/client": "^5.1.1",
    "@react-email/render": "^2.0.8",
    "@types/ioredis": "5.0.0",
    "@types/node": "20.4.4",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "autoprefixer": "10.4.14",
    "cookies-next": "^2.1.2",
    "dotenv": "^16.3.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "firebase": "^12.14.0",
    "firebase-admin": "^11.10.1",
    "formik": "^2.4.4",
    "ioredis": "5.3.2",
    "next": "16.2.9",
    "openai": "^4.4.0",
    "postcss": "8.5.15",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-query": "^3.39.3",
    "react-toastify": "^11.1.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.4",
    "tailwindcss": "3.3.3",
    "types": "^0.1.1",
    "typescript": "5.1.6",
    "yet-another-react-lightbox": "^3.12.2",
    "yup": "^1.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.38.1",
    "@types/google.maps": "^3.65.1",
    "checkly": "latest",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.1.1",
    "sass": "^1.66.1",
    "ts-node": "latest",
    "typescript": "latest"
  }
}
