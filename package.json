{
  "name": "real-estate-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma-db-push-dev": "dotenv -e .env.development -- npx prisma db push",
    "prisma-db-push-remote": "dotenv -e .env.production.local --override -- npx prisma db push",
    "prisma-db-generate-dev": "dotenv -e .env.development -- npx prisma generate",
    "prisma-db-seed-dev": "dotenv -e .env.development -- npx tsx prisma/seed.ts",
    "prisma-db-seed-dev:remote-images": "dotenv -e .env.development -v SEED_IMAGE_SOURCE=remote -- npx tsx prisma/seed.ts",
    "prisma-db-seed-remote": "dotenv -e .env.production.local --override -v SEED_IMAGE_SOURCE=remote -- npx tsx prisma/seed.ts",
    "prisma-db-setup-dev": "npm run prisma-db-push-dev && npm run prisma-db-seed-dev",
    "prisma-db-setup-remote": "npm run prisma-db-push-remote && npm run prisma-db-seed-remote",
    "sitemap:print": "dotenv -e .env.development -- npx tsx scripts/print-sitemap.ts",
    "sitemap:save": "dotenv -e .env.development -- npx tsx scripts/print-sitemap.ts --save",
    "sitemap:print:prod": "dotenv -e .env.production.local --override -- npx tsx scripts/print-sitemap.ts",
    "sitemap:save:prod": "dotenv -e .env.production.local --override -- npx tsx scripts/print-sitemap.ts --save"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.2.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.101.0",
    "@types/node": "25.9.3",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "autoprefixer": "10.5.0",
    "cookies-next": "^6.1.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "firebase": "^12.15.0",
    "firebase-admin": "^11.10.1",
    "formik": "^2.4.9",
    "ioredis": "5.11.1",
    "next": "16.2.9",
    "postcss": "8.5.15",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-toastify": "^11.1.0",
    "recharts": "^3.8.1",
    "resend": "^6.14.0",
    "tailwindcss": "3.3.3",
    "yet-another-react-lightbox": "^3.12.2",
    "yup": "^1.7.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/google.maps": "^3.65.1",
    "checkly": "8.8.0",
    "dotenv-cli": "^11.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "sass": "^1.101.0",
    "tsx": "^4.22.4",
    "typescript": "6.0.3"
  }
}
